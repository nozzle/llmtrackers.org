{
  "name": "llm-tracker-comparison",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "NODE_OPTIONS=\"${NODE_OPTIONS:+$NODE_OPTIONS }--inspect-port=0\" pnpm exec vite dev",
    "dev:server": "pnpm exec wrangler dev",
    "prebuild": "pnpm compile-data",
    "build": "pnpm exec vite build && pnpm exec tsx scripts/generate-sitemap.ts",
    "predeploy:check": "pnpm build",
    "deploy:check": "pnpm exec wrangler deploy --dry-run",
    "predeploy": "pnpm build",
    "deploy": "pnpm exec wrangler deploy",
    "compile-data": "pnpm --filter @llm-tracker/shared compile",
    "backfill-review-sites": "pnpm exec tsx src/server/update/backfill-review-sites.ts",
    "cf-typegen": "pnpm exec wrangler types",
    "lint": "eslint .",
    "preview": "pnpm exec vite preview",
    "check": "pnpm lint && pnpm test && pnpm typecheck && pnpm build",
    "pretypecheck": "pnpm compile-data",
    "test": "vitest run",
    "typecheck": "pnpm exec tsc --noEmit && pnpm --filter @llm-tracker/shared typecheck && pnpm --filter @llm-tracker/github typecheck"
  },
  "dependencies": {
    "@llm-tracker/github": "workspace:*",
    "@llm-tracker/shared": "workspace:*",
    "@tanstack/react-router": "^1.114.0",
    "@tanstack/react-start": "^1.166.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.13.3",
    "@eslint/js": "^9.21.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^25.3.5",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.21.0",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.24.1",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^6.1.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.71.0"
  },
  "engines": {
    "node": ">=24"
  }
}
