{
  "name": "llm-tracker-comparison",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm compile-data && pnpm --filter web build",
    "compile-data": "pnpm --filter @llm-tracker/shared compile",
    "backfill-review-sites": "pnpm --filter update-checker backfill-review-sites",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "typecheck": "pnpm compile-data && pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "typescript-eslint": "^8.24.1",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=24"
  }
}
